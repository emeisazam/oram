# oram environment variables
# copy to .env and fill in values as needed

# audio
ORAM_SAMPLE_RATE=
ORAM_BLOCK_SIZE=
ORAM_INPUT_DEVICE=
ORAM_OUTPUT_DEVICE=

# session
ORAM_SESSION_DIR=

# backends
ORAM_STT_BACKEND=
ORAM_GENERATOR_BACKEND=
ORAM_LLM_BACKEND=

# listening
ORAM_AUTO_LISTEN=
ORAM_DEFAULT_LISTENING_ROUTE=
ORAM_DEFAULT_ENGINE=

# engine router
ORAM_ENGINE_ROUTER_MODE=auto
ORAM_PREFERRED_PROVIDER=

# dashboard security
ORAM_DASHBOARD_TOKEN=

# engine providers (server-side only, never exposed to frontend)
ELEVENLABS_API_KEY=
STABILITY_API_KEY=
HF_TOKEN=
FAL_KEY=
REPLICATE_API_TOKEN=
